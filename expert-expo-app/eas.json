{
  "cli": {
    "version": ">= 10.0.0",
    "requireCommit": true
  },
  "build": {
    "preview": {
      "environment": "preview",
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "KONNECTPRO_EAS_EXPERT_EXPO": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "environment": "production",
      "env": {
        "KONNECTPRO_EAS_EXPERT_EXPO": "1"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
