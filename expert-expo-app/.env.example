# Copy to `.env` in this folder and fill in your Supabase project values (Dashboard → Settings → API).
# Expo exposes only EXPO_PUBLIC_* to the app bundle (inlined at bundle time). VITE_SUPABASE_* is for the
# Vite web app only and is ignored by Metro / EAS for this project.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# EAS / preview & production APKs: the same EXPO_PUBLIC_* names MUST exist for the build profile’s
# environment (Expo dashboard → Project → Environment variables) or `eas env:push`. A missing URL/key
# produces a “dead” Google button (no browser) because the Supabase client targets an empty host.

# Not read by this app: OAuth is server-side via Supabase (enable Google provider + Web client there).
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Expo Push (assignment alerts): run `eas init` in this folder and paste the project ID from app.json / EAS dashboard.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Google OAuth (Expo): add this exact redirect URL in
# Supabase Dashboard → Authentication → URL configuration → Redirect URLs:
#   expert-expo-app://auth/callback

# Dev / Expo Go only: skip experts-table gate and open dashboard after sign-in.
# Leave unset or false for production and EAS release builds (normal validateExpertAccess).
# EXPO_PUBLIC_FORCE_EXPERT_MODE=true
