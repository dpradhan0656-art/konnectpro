# Supabase (replace with your project values)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# DeepakHQ bypass: co-founder emails that may access HQ without an `app_admin` row (comma-separated).
# Also supports VITE_SUPERADMIN_EMAIL=single@email.com
# VITE_SUPERADMIN_EMAILS=founder@company.com
# VITE_SUPERADMIN_EMAIL=

# Razorpay – TEST key (commented when using LIVE)
# VITE_RAZORPAY_KEY_ID=rzp_test_SMf9Z871aJmL76

# Razorpay – LIVE key (use your live key from Razorpay Dashboard → Settings → API Keys)
VITE_RAZORPAY_KEY_ID=rzp_live_YOUR_LIVE_KEY_ID
